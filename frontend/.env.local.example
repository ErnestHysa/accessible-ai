# AccessibleAI - Frontend Environment Configuration
# Copy this file to .env.local and fill in the values

# ============================================================================
# API
# ============================================================================
NEXT_PUBLIC_API_URL=https://api.accessibleai.com

# ============================================================================
# STRIPE
# ============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ============================================================================
# MONITORING
# ============================================================================
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxx.ingest.sentry.io/xxxxx

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================
# Get your site ID from https://plausible.io/
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=accessibleai.com

# Or Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================================================
# FEATURES
# ============================================================================
NEXT_PUBLIC_APP_URL=https://accessibleai.com
