# AccessibleAI - Backend Environment Configuration
# Copy this file to .env and fill in the values

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql+asyncpg://accessibleai:your_password_here@localhost:5432/accessible_ai

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# SECURITY
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# AI/OPENAI
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================================
# STRIPE PAYMENT PROCESSING
# ============================================================================
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_WEBHOOK_ENDPOINT=https://api.accessibleai.com/api/v1/webhook/stripe

# Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_ID_STARTER=price_xxxxxxxx
STRIPE_PRICE_ID_PRO=price_xxxxxxxx
STRIPE_PRICE_ID_AGENCY=price_xxxxxxxx

# ============================================================================
# APPLICATION
# ============================================================================
BASE_URL=https://api.accessibleai.com
FRONTEND_URL=https://accessibleai.com
ALLOWED_ORIGINS=https://accessibleai.com,https://www.accessibleai.com

# ============================================================================
# MONITORING
# ============================================================================
# Get your DSN from https://sentry.io/settings/projects/
SENTRY_DSN=https://xxxxxxxxx.ingest.sentry.io/xxxxx

# ============================================================================
# EMAIL (Optional - using Resend)
# ============================================================================
# Get your API key from https://resend.com/api/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
SMTP_FROM=AccessibleAI <noreply@accessibleai.com>

# ============================================================================
# FEATURES
# ============================================================================
DEBUG=false
SCAN_TIMEOUT_SECONDS=60
MAX_PAGES_PER_SCAN=100
SCAN_CONCURRENCY=5

# ============================================================================
# CORS
# ============================================================================
# Comma-separated list of allowed origins for API access
# ALLOWED_ORIGINS=https://accessibleai.com,https://www.accessibleai.com

# ============================================================================
# WP-PLAYWRIGHT (For WordPress plugin scanning)
# ============================================================================
# Playwright browser path for headless scanning
PLAYWRIGHT_BROWSER_PATH=/usr/bin/chromium
