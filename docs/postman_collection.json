{
  "info": {
    "name": "AccessibleAI API",
    "description": "API collection for AccessibleAI accessibility compliance platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "websiteId",
      "value": "",
      "type": "string"
    },
    {
      "key": "scanId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save tokens from response",
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', data.access_token);",
                  "    pm.collectionVariables.set('refreshToken', data.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"TestPass123!\",\n  \"name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save tokens from response",
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', data.access_token);",
                  "    pm.collectionVariables.set('refreshToken', data.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"TestPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Websites",
      "item": [
        {
          "name": "List Websites",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/websites",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "websites"]
            }
          }
        },
        {
          "name": "Create Website",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('websiteId', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com\",\n  \"name\": \"Example Website\",\n  \"platform\": \"generic\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/websites",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "websites"]
            }
          }
        },
        {
          "name": "Get Website",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/websites/{{websiteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "websites", "{{websiteId}}"]
            }
          }
        },
        {
          "name": "Delete Website",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/websites/{{websiteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "websites", "{{websiteId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Scans",
      "item": [
        {
          "name": "Trigger Scan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('scanId', data.scan_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_scan\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/websites/{{websiteId}}/scan",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "websites", "{{websiteId}}", "scan"]
            }
          }
        },
        {
          "name": "Get Scan Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/scans/{{scanId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "scans", "{{scanId}}"]
            }
          }
        },
        {
          "name": "Get Scan Issues",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/scans/{{scanId}}/issues",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "scans", "{{scanId}}", "issues"]
            }
          }
        },
        {
          "name": "Get Scan History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/scans",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "scans"]
            }
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Create Checkout Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tier\": \"starter\",\n  \"success_url\": \"http://localhost:3000/dashboard/settings/billing\",\n  \"cancel_url\": \"http://localhost:3000/dashboard/settings/billing\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscriptions/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "subscriptions", "checkout"]
            }
          }
        },
        {
          "name": "Get Subscription Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscriptions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "subscriptions"]
            }
          }
        },
        {
          "name": "Cancel Subscription",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscriptions/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "subscriptions", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Database Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health/db",
              "host": ["{{baseUrl}}"],
              "path": ["health", "db"]
            }
          }
        },
        {
          "name": "Redis Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health/redis",
              "host": ["{{baseUrl}}"],
              "path": ["health", "redis"]
            }
          }
        },
        {
          "name": "Celery Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health/celery",
              "host": ["{{baseUrl}}"],
              "path": ["health", "celery"]
            }
          }
        },
        {
          "name": "Detailed Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health/detailed",
              "host": ["{{baseUrl}}"],
              "path": ["health", "detailed"]
            }
          }
        }
      ]
    }
  ]
}
